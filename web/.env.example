# Rico Web Environment Variables

# API Port (optional - default: 8080)
# Use this to connect to a different backend port
VITE_API_PORT=8080

# API Base URL (optional - overrides VITE_API_PORT if set)
# VITE_API_BASE=https://localhost:8080

# VAPID Public Key (required for push notifications)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
